# Required
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# DM embed appearance
BRAND_NAME=Smoke - SmokeURLs
STORE_URL=https://your-store-link.com
BANNER_URL=https://your-banner-image-url.com/banner.png
ICON_URL=https://your-icon-url.com/icon.png

# DMs are OFF by default to prevent Discord quarantine.
# Appeal at https://dis.gd/app-quarantine then set this to true.
SEND_DMS=false

# Railway Volume mount path for persistent data
DATA_DIR=/data

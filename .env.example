# Required
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# DM embed appearance
BRAND_NAME=Smoke - SmokeURLs
STORE_URL=https://your-store-link.com
BANNER_URL=https://your-banner-image-url.com/banner.png
ICON_URL=https://your-icon-url.com/icon.png

# Gap between each DM send in milliseconds.
# 1200 = ~50 DMs/min (safe default). Lower = faster but higher quarantine risk.
DM_DELAY=1200

# Railway Volume mount path
DATA_DIR=/data
